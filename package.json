{
  "name": "apparel-video",
  "private": true,
  "version": "0.3.1",
  "description": "Video Sản Phẩm - tạo video thời trang cinematic (người mẫu mặc sản phẩm) bằng AI Veo cho Kozmoz Studio",
  "author": "Kozmoz Studio",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "make-icon": "node scripts/make-icon.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5175 && cross-env ELECTRON_DEV=1 electron .\"",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.39",
    "sharp": "^0.33.4",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kozmozstudio.apparelvideo",
    "productName": "Video San Pham",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    },
    "portable": {
      "artifactName": "Video-San-Pham-${version}-portable.exe"
    }
  }
}
